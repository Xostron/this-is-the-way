{
	"name": "back-n1",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "nodemon ./src/bin/www",
		"start": "node ./src/bin/www"
	},
	"nodemonConfig": {
		"ignore": [
			"src/public/*"
		]
	},
	"_moduleAliases": {
		"@root": "src/",
		"@routes": "src/routes",
		"@socket": "src/socket",
		"@service": "src/service",
		"@middlew": "src/middlew",
		"@dict": "src/dict",
		"@tool": "src/tool",
		"@util": "src/util",
		"@store": "src/store"
	},
	"dependencies": {
		"@tensorflow/tfjs": "^4.22.0",
		"axios": "^1.18.1",
		"bcrypt": "^6.0.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"debug": "^4.4.3",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-fileupload": "^1.5.2",
		"http-errors": "^2.0.1",
		"jsmodbus": "^4.0.10",
		"jsonwebtoken": "^9.0.3",
		"module-alias": "^2.3.4",
		"mongojs": "^3.1.0",
		"morgan": "^1.11.0",
		"pug": "3.0.4",
		"serialport": "^13.0.0",
		"socket.io": "^4.8.3",
		"uuid": "^14.0.1"
	},
	"devDependencies": {
		"nodemon": "^3.1.14"
	}
}
